# AI Tools Hub - Frontend Environment Variables Template
# Copy this file to '.env' or '.env.production' to use these variables.

# URL of your deployed backend API (e.g., hosted on Render, Heroku, etc.)
# If left blank, the frontend will automatically use relative paths (best if hosted on the same domain).
# Example: VITE_API_URL=https://your-backend-api.onrender.com
VITE_API_URL=
