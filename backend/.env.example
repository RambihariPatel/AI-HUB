# Example environment variables for the BACKEND
# For LOCAL development:
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai-tools-hub
JWT_SECRET=supersecretjwtkey123
FRONTEND_URL=http://localhost:5173

# For PRODUCTION (Render):
# PORT=5000
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-tools-hub
# JWT_SECRET=<generate a strong random 64-char string>
# FRONTEND_URL=https://your-app.vercel.app
# NODE_ENV=production
